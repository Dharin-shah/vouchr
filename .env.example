# Vouchr. Copy to .env and fill in.

# Root key for token encryption at rest (base64, 32 bytes).
#   openssl rand -base64 32
VOUCHR_MASTER_KEY=

# Master-key rotation (optional): comma-separated id:base64key entries. The FIRST entry
# encrypts new writes; every entry decrypts. Rotate with `vouchr rekey` — see
# guides/DEPLOYMENT.md "Key rotation".
# VOUCHR_MASTER_KEYS=k2026:...,k2019:...

# PostgreSQL connection string (required — Vouchr is Postgres-only and fails closed at boot if this
# is unset or not a postgres:// URL). Run `npm run cli -- migrate` once against it before starting.
# TLS is native: add sslmode=require (or stricter, e.g. verify-full) to the URL to negotiate it.
VOUCHR_DATABASE_URL=postgres://vouchr:vouchr@localhost:5432/vouchr

# --- Headless broker identity (required by vouchr-broker and its trusted minter) ---
# Random HS256 key, at least 32 bytes and distinct from every other secret.
#   openssl rand -base64 32
VOUCHR_IDENTITY_SECRET=
# Stable id shared by this deployment's trusted minter and every broker replica.
VOUCHR_DEPLOYMENT_ID=vouchr-production
# Optional single overlap key during the documented two-rollout rotation.
# VOUCHR_IDENTITY_SECRET_PREVIOUS=

# --- Slack app (the bot acting in your workspace) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Public origin where Slack/GitHub can reach the OAuth callback.
# In dev: run `ngrok http 3000` and paste the https URL here.
PUBLIC_URL=https://your-subdomain.ngrok.io
PORT=3000

# --- GitHub OAuth App ---
# Authorization callback URL must be: $PUBLIC_URL/vouchr/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
