{
  "name": "@vouchr/core",
  "version": "0.2.0-rc.1",
  "description": "Self-hostable, Slack-native credential broker for AI agents.",
  "license": "Apache-2.0",
  "author": "Dharin Shah",
  "homepage": "https://github.com/Dharin-shah/vouchr#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dharin-shah/vouchr.git"
  },
  "bugs": {
    "url": "https://github.com/Dharin-shah/vouchr/issues"
  },
  "keywords": [
    "slack",
    "oauth",
    "credentials",
    "ai-agents",
    "bolt",
    "secrets",
    "security"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/src/index.js"
    },
    "./headless": {
      "types": "./dist/src/headless.d.ts",
      "require": "./dist/src/headless.js"
    },
    "./broker-server": {
      "types": "./dist/bin/broker-server.d.ts",
      "require": "./dist/bin/broker-server.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src/**",
    "dist/bin/**",
    "assets/**",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "guides/**"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "vouchr": "dist/bin/vouchr.js",
    "vouchr-broker": "dist/bin/broker-server.js",
    "vouchr-seed": "dist/bin/broker-seed.js"
  },
  "scripts": {
    "cli": "node --import tsx bin/vouchr.ts",
    "broker": "node --import tsx bin/broker-server.ts",
    "seed": "node --import tsx bin/broker-seed.ts",
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint src bin test",
    "test": "node --import tsx --test test/*.test.ts",
    "pack-smoke": "bash test/pack-smoke.sh",
    "pg:up": "docker run --rm -d --name vouchr-pg -e POSTGRES_USER=vouchr -e POSTGRES_PASSWORD=vouchr -e POSTGRES_DB=vouchr -p 5433:5432 postgres:16-alpine",
    "pg:down": "docker rm -f vouchr-pg",
    "example:github": "node --env-file=.env --import tsx examples/bolt-github/app.ts"
  },
  "dependencies": {
    "@slack/bolt": "^3.22.0",
    "@slack/web-api": "^7.18.0",
    "better-sqlite3": "^12.11.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1075.0",
    "@biomejs/biome": "^2.5.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3"
  }
}
